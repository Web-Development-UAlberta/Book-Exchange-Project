@using System.Security.Claims
@model Book_Exchange.Models.DTOs.Listing.ListingViewDto

@{
    ViewData["Title"] = "Listing Details";
    var currentUserId =
            User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner =
        currentUserId == Model.UserId.ToString();
}

<div id="listing-detail-page" class="container mt-4">

    <div class="row">

        <div class="col-md-5">

            @if (!string.IsNullOrWhiteSpace(Model.Book?.ThumbnailUrl))
            {
                <img id="listing-cover"
                     src="@Model.Book.ThumbnailUrl"
                     class="img-fluid border p-3"
                     alt="@Model.Book.Title" />
            }
            else
            {
                <div id="listing-cover"
                     class="border d-flex align-items-center justify-content-center"
                     style="height:300px;">
                    Cover
                </div>
            }

            <h5 id="condition-guide" class="mt-4">Condition Guide</h5>

            <div class="d-flex gap-2 mt-2">
                <span class="btn btn-outline-secondary condition-cell @(Model.Condition == Book_Exchange.Models.BookCondition.LikeNew ? "condition-cell-active" : "")">
                    LN<br />Like New
                </span>

                <span class="btn btn-outline-secondary condition-cell @(Model.Condition == Book_Exchange.Models.BookCondition.VeryGood ? "condition-cell-active" : "")">
                    VG<br />Very Good
                </span>

                <span class="btn btn-outline-secondary condition-cell @(Model.Condition == Book_Exchange.Models.BookCondition.Good ? "condition-cell-active" : "")">
                    GD<br />Good
                </span>

                <span class="btn btn-outline-secondary condition-cell @(Model.Condition == Book_Exchange.Models.BookCondition.Poor ? "condition-cell-active" : "")">
                    PR<br />Poor
                </span>
            </div>

        </div>

        <div class="col-md-4">

            <h1 id="listing-book-title">
                @(Model.Book?.Title ?? "Unknown Title")
            </h1>

            <p id="listing-author-name">
                By @(Model.Book?.Authors.Any() == true
                                    ? string.Join(", ", Model.Book.Authors)
                                    : "Unknown Author")
            </p>

            <p id="listing-price">
                Price: $@Model.Price
            </p>

            <p>
                Listed @Model.CreatedAt.ToString("MMM dd, yyyy")
                -
                Genre @(Model.Book?.Genres.Any() == true
                                    ? string.Join(", ", Model.Book.Genres)
                                    : "N/A")
            </p>

            <span id="listing-condition-badge" class="badge bg-secondary">
                @Model.Condition
            </span>

            <span class="badge bg-light text-dark border">
                @(Model.WeightGrams / 1000.0) kg
            </span>

        </div>

        <div class="col-md-3">
            @if (!isOwner)

            {
                <div id="listing-seller-card" class="card p-3">

                <p>Listed by</p>

                <p id="listing-seller-name">
                    @Model.SellerName
                </p>

                <!---<p id="listing-seller-rating">
                    ★★★★☆ - 18 trades
                </p>-->
                <!-- TODO: check this buttons -->
                    <a id="exchange-request-btn"
                            class="btn btn-outline-primary mb-2"
                            asp-controller="ExchangeRequest"
                            asp-action="Create"
                            asp-route-listingId="@Model.Id">
                        Exchange Request
                    </a>

                    <a id="message-seller-btn"
                            class="btn btn-outline-primary"
                            asp-controller="Message"
                            asp-action="Create"
                            asp-route-listingId="@Model.Id">
                        Message Seller
                    </a>
                    <!-- TODO: check this buttons -->
                    <a id= "propose-swap-btn"
                            class="btn btn-outline-secondary mt-2"
                            asp-controller="ExchangeRequest"
                            asp-action="ProposeSwap"
                            asp-route-listingId="@Model.Id">
                        Propose Swap
                    </a>
                    <a id= "send-offer-btn"
                            class="btn btn-outline-secondary mt-2"
                            asp-controller="Offer"
                            asp-action="Create"
                            asp-route-listingId="@Model.Id">
                        Send Offer
                    </a>

            </div>
            // TODO: Need to Add SellerAddressID to Listing Model to show shipping as well add GetDefaultAddressAsync to IAddressService and implement it in AddressService.
            // TODO: Update Listing Controller Details to populat shipping esimte if user hase default address.
            // TODO: then update this with <partial name="_ShippingEstimate" model="Model.ShippingEstimate" />
            <!--<div id="shipping-estimate" class="card p-3 mt-4 text-center">
                <p>Estimated Shipping</p>
                <strong>$12.00</strong>
                <small>Based on weight and location</small>
            </div>-->
            }

            <a id="listing-view-btn"
                   asp-controller="Listing"
                   asp-action="Index"
                   class="btn btn-secondary mt-4 w-100">
                Back to Listings
            </a>

        </div>

    </div>

</div>