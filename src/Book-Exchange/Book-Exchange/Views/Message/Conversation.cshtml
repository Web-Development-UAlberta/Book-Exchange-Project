@model IEnumerable<Book_Exchange.Models.Message>
@using System.Security.Claims
@{
    ViewData["Title"] = "Conversation";
    var currentUserId = Guid.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
    var otherUserId   = (Guid)ViewBag.OtherUserId;
    var messages      = Model.ToList();
    var otherUserName = messages.FirstOrDefault(m => m.SenderId == otherUserId)?.Sender?.UserName
                     ?? messages.FirstOrDefault(m => m.ReceiverId == otherUserId)?.Receiver?.UserName
                     ?? "User";
}

<div id="messages-page">

    <div id="chat-panel" class="d-flex" style="height: calc(100vh - 180px); border: 1px solid #dee2e6; border-radius: 6px; overflow: hidden;">

        @* Conversation List Sidebar *@
        <div id="conversation-list" style="width: 280px; min-width: 220px; border-right: 1px solid #dee2e6; overflow-y: auto; background: #f8f9fa; display: none;">
            @* populated by partial in a full layout; hidden in standalone view *@
        </div>

        @* Active Chat Panel *@
        <div class="conversation-item-active flex-grow-1 d-flex flex-column">

            @* Chat Header *@
            <div id="chat-header" class="d-flex align-items-center gap-3 p-3 border-bottom bg-white">
                <div class="user-avatar rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width: 44px; height: 44px; font-size: 1.1rem; font-weight: 600;">
                    @otherUserName.FirstOrDefault().ToString().ToUpper()
                </div>
                <div>
                    <div class="fw-semibold">@otherUserName</div>
                </div>
                <a asp-action="Index" class="ms-auto btn btn-sm btn-outline-secondary">← Back</a>
            </div>

            @* Message Thread *@
            <div id="message-thread" class="flex-grow-1 overflow-y-auto p-3 d-flex flex-column gap-2" style="background: #f0f2f5;">

                @if (!messages.Any())
                {
                    <div class="text-center text-muted mt-5">
                        No messages yet. Send one below!
                    </div>
                }

                @foreach (var msg in messages)
                {
                    var isOutgoing = msg.SenderId == currentUserId;

                    <div class="message-item @(isOutgoing ? "message-item-outgoing" : "message-item-incoming") d-flex @(isOutgoing ? "justify-content-end" : "justify-content-start")"
                         data-message-id="@msg.Id">

                        @if (!isOutgoing)
                        {
                            <div class="user-avatar rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center flex-shrink-0 me-2"
                                 style="width: 34px; height: 34px; font-size: 0.85rem; align-self: flex-end;">
                                @otherUserName.FirstOrDefault().ToString().ToUpper()
                            </div>
                        }

                        <div style="max-width: 60%;">

                            @* Optional: Offer/Exchange Bubble *@
                            @if (msg.ExchangeRequestId.HasValue || msg.ListingId.HasValue || msg.TransactionId.HasValue)
                            {
                                <div class="offer-message p-2 mb-1 border rounded bg-white" style="font-size: 0.82rem;">
                                    <div class="fw-semibold text-muted mb-1">Swap Offer</div>
                                    @if (msg.Listing != null)
                                    {
                                        <div>Listing: <span class="fw-semibold">@msg.Listing.Isbn</span></div>
                                    }
                                    @if (msg.ExchangeRequest != null)
                                    {
                                        <div class="mt-1 d-flex gap-2">
                                            <a asp-controller="ExchangeRequest" asp-action="Accept"
                                               asp-route-id="@msg.ExchangeRequestId"
                                               class="offer-accept-btn btn btn-sm btn-success py-0">Accept</a>
                                            <a asp-controller="ExchangeRequest" asp-action="Decline"
                                               asp-route-id="@msg.ExchangeRequestId"
                                               class="offer-decline-btn btn btn-sm btn-danger py-0">Decline</a>
                                        </div>
                                    }
                                </div>
                            }

                            @* Main message bubble *@
                            <div class="px-3 py-2 rounded-3 @(isOutgoing ? "bg-primary text-white" : "bg-white border")"
                                 style="font-size: 0.9rem; word-break: break-word;">
                                @msg.MessageText
                            </div>

                            <div class="text-muted mt-1 @(isOutgoing ? "text-end" : "text-start")"
                                 style="font-size: 0.72rem;">
                                @msg.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")
                                @if (isOutgoing)
                                {
                                    <span class="ms-1">@(msg.IsRead ? "✓✓" : "✓")</span>
                                }
                            </div>
                        </div>

                    </div>
                }
            </div>

            @* Message Input Bar *@
            <div class="border-top bg-white p-3 d-flex gap-2 align-items-end">
                <form asp-action="Send" method="post" class="d-flex gap-2 flex-grow-1 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReceiverId" value="@otherUserId" />

                    <textarea id="message-input"
                              name="MessageText"
                              class="form-control"
                              placeholder="Type Message"
                              rows="1"
                              maxlength="2000"
                              style="resize: none; overflow-y: hidden;"
                              oninput="autoResize(this)"
                              required></textarea>

                    <button id="message-send-btn" type="submit" class="btn btn-primary px-4">Send</button>
                </form>

                @* Character counter *@
                <div class="offer-counter text-muted" style="font-size: 0.75rem; white-space: nowrap; align-self: center;">
                    <span id="char-count">0</span>/2000
                </div>
            </div>

        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-2">@TempData["Error"]</div>
    }

</div>

@section Scripts {
    <script>
        @* Auto-scroll to bottom of message thread on load *@
        const thread = document.getElementById('message-thread');
        if (thread) thread.scrollTop = thread.scrollHeight;

        @* Auto-resize textarea *@
        function autoResize(el) {
            el.style.height = 'auto';
            el.style.height = Math.min(el.scrollHeight, 120) + 'px';
            const counter = document.getElementById('char-count');
            if (counter) counter.textContent = el.value.length;
        }

        @* Wire up counter on load *@
        const input = document.getElementById('message-input');
        if (input) {
            input.addEventListener('input', () => {
                const counter = document.getElementById('char-count');
                if (counter) counter.textContent = input.value.length;
            });
        }
    </script>
}
