@model Book_Exchange.Models.DTOs.Wishlist.WishlistIndexViewDto

@{
    ViewData["Title"] = "My Wishlist";
}

<div id="wishlist-page" class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            My wishlist
            <small id="wishlist-count" class="text-muted">
                (@Model.Items.Count books)
                <!-- FIXME: this isn't updating when a book is removed from the wishlist -->
            </small>
        </h2>

        <button id="wishlist-add-btn"
                type="button"
                class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addWishlistModal">
            + Add Book
        </button>
    </div>

    <form asp-controller="Wishlist"
          asp-action="Index"
          method="get"
          class="row g-2 mb-4">

        <div class="col-md-4">
            <input id="wishlist-search-input"
                   type="text"
                   name="searchText"
                   value="@Model.SearchText"
                   class="form-control"
                   placeholder="Search wishlist..." />
        </div>

        <div class="col-auto">
            <button id="wishlist-filter-available-btn"
                    type="submit"
                    name="availableOnly"
                    value="true"
                    class="btn btn-outline-primary">
                Available only
            </button>
        </div>

        <div class="col-auto">
            <a id="wishlist-filter-all-btn"
                   asp-controller="Wishlist"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                Show all
            </a>
        </div>

    </form>

    <div id="wishlist-items-list">

        @foreach (var item in Model.Items)
        {
            <div class="wishlist-item card mb-3">
                <div class="card-body">

                    <div class="row align-items-center">

                        <div class="col-md-1">
                            @if (!string.IsNullOrWhiteSpace(item.Book?.ThumbnailUrl))
                            {
                                <img src="@item.Book.ThumbnailUrl"
                                     class="wishlist-item-cover img-fluid border"
                                     alt="@item.Book.Title" />
                            }
                            else
                            {
                                <div class="wishlist-item-cover border d-flex align-items-center justify-content-center"
                                     style="height:90px;">
                                    Cover
                                </div>
                            }
                        </div>

                        <div class="col-md-5">
                            <h4 class="wishlist-item-title mb-2">
                                @(item.Book?.Title ?? "Unknown Title")
                            </h4>

                            <p class="wishlist-item-author mb-1">
                                @(item.Book?.Authors.Any() == true
                                    ? string.Join(", ", item.Book.Authors)
                                    : "Unknown Author")
                            </p>

                            <small class="text-muted">
                                ISBN: @item.Isbn
                            </small>
                        </div>

                        <div class="col-md-6 text-md-end mt-3 mt-md-0">

                            @if (item.HasMatchingListing)
                            {
                                <span class="wishlist-availability-badge badge bg-success me-2">
                                    Available
                                </span>

                                <a asp-controller="Wishlist"
                                       asp-action="Matches"
                                       asp-route-id="@item.Id"
                                       class="wishlist-view-listings-btn btn btn-outline-primary btn-sm me-2">
                                    View Listings
                                </a>
                            }
                            else
                            {
                                <span class="wishlist-availability-badge badge bg-secondary me-2">
                                    Not listed
                                </span>

                                <button type="button"
                                        class="wishlist-notify-btn btn btn-outline-warning btn-sm me-2"
                                        disabled>
                                    Notify Me
                                </button>
                            }

                            @if (item.IsActive)
                            {
                                <form asp-controller="Wishlist"
                                      asp-action="Remove"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="wishlist-remove-btn btn btn-outline-danger btn-sm">
                                        Remove
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Wishlist"
                                      asp-action="Restore"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="wishlist-restore-btn btn btn-outline-success btn-sm">
                                        Restore
                                    </button>
                                </form>
                            }

                        </div>

                    </div>

                </div>
            </div>
        }
        @if (!Model.Items.Any())
        {
            <p id="no-wishlist-message" class="text-muted">You have no books in your wishlist yet.</p>
        }
    </div>

</div>

<div class="modal fade"
     id="addWishlistModal"
     tabindex="-1"
     aria-labelledby="addWishlistModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="addWishlistModalLabel" class="modal-title">
                    Add Book to Wishlist
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                </button>
            </div>

            <div class="modal-body">

                <div class="input-group mb-3">
                    <input id="wishlist-book-search-input"
                           type="text"
                           class="form-control"
                           placeholder="Search by title, author, or ISBN" />

                    <button id="wishlist-book-search-btn"
                            type="button"
                            class="btn btn-primary">
                        Search
                    </button>
                </div>

                <div id="wishlist-book-search-results"
                     class="list-group">
                </div>

                <form id="wishlist-add-form"
                      asp-controller="Wishlist"
                      asp-action="Add"
                      method="post"
                      class="mt-3">

                    @Html.AntiForgeryToken()

                    <input id="wishlist-selected-isbn"
                           type="hidden"
                           name="isbn" />

                    <button id="wishlist-confirm-add-btn"
                            type="submit"
                            class="btn btn-success"
                            disabled>
                        Add Selected Book
                    </button>

                </form>

            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        document
            .getElementById("wishlist-book-search-btn")
            .addEventListener("click", async function () {

                const searchText =
                    document.getElementById("wishlist-book-search-input").value;

                if (!searchText || searchText.trim() === "") {
                    return;
                }

                const response =
                    await fetch(`/Wishlist/SearchBooks?searchText=${encodeURIComponent(searchText)}`);

                const books = await response.json();

                const resultsDiv =
                    document.getElementById("wishlist-book-search-results");

                resultsDiv.innerHTML = "";

                if (!books || books.length === 0) {
                    resultsDiv.innerHTML =
                        `<div class="alert alert-warning">No books found.</div>`;
                    return;
                }

                books.forEach(book => {

                    const isbn = book.isbn13 || book.isbn10 || "";

                    if (!isbn) {
                        return;
                    }

                    const button = document.createElement("button");

                    button.type = "button";
                    button.className = "list-group-item list-group-item-action wishlist-book-result-item";

                    button.innerHTML = `
                        <div class="d-flex align-items-center">
                            <img src="${book.thumbnail ?? ""}"
                                 style="height:80px; width:60px; object-fit:contain;"
                                 class="me-3 border"
                                 alt="Book Cover" />

                            <div class="text-start">
                                <strong class="wishlist-book-result-title">
                                    ${book.title ?? "Unknown Title"}
                                </strong>

                                <div>
                                    ${(book.authors || []).join(", ")}
                                </div>

                                <small>
                                    Published: ${book.publishedYear ?? "N/A"}
                                </small>

                                <br />

                                <small>
                                    ISBN: ${isbn}
                                </small>
                            </div>
                        </div>
                    `;

                    button.addEventListener("click", function () {

                        document.getElementById("wishlist-selected-isbn").value = isbn;

                        document
                            .getElementById("wishlist-confirm-add-btn")
                            .disabled = false;

                        document
                            .querySelectorAll(".wishlist-book-result-item")
                            .forEach(x => x.classList.remove("active"));

                        button.classList.add("active");
                    });

                    resultsDiv.appendChild(button);
                });
            });
    </script>
}