@model IEnumerable<Book_Exchange.Models.Listing>

@{
    ViewData["Title"] = "Matching Listings";
}

<div class="container mt-4">

    <h2>Matching Listings</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning mt-3">
            No matching listings found.
        </div>
    }
    else
    {
        <div class="list-group mt-3">

            @foreach (var listing in Model)
            {
                <a asp-controller="Listing"
                       asp-action="Details"
                       asp-route-id="@listing.Id"
                       class="list-group-item list-group-item-action">

                    <strong>ISBN:</strong> @listing.Isbn
                    |
                    <strong>Condition:</strong> @listing.Condition
                    |
                    <strong>Price:</strong> $@listing.Price

                </a>
            }

        </div>
    }

    <a asp-controller="Wishlist"
           asp-action="Index"
           class="btn btn-secondary mt-3">
        Back to Wishlist
    </a>

</div>