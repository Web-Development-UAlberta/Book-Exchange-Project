@model Book_Exchange.Models.Shipment
@{
    ViewData["Title"] = "Shipment Details";
    bool isSender = (bool)ViewBag.IsSender;
    string shipmentRef = (string)ViewBag.ShipmentReference;
    string myRole    = isSender ? "Sender"   : "Receiver";
    string theirRole = isSender ? "Receiver" : "Sender";
    var myAddress    = isSender ? Model.SenderAddress   : Model.ReceiverAddress;
    var theirAddress = isSender ? Model.ReceiverAddress : Model.SenderAddress;

    bool isTerminal = Model.Status == Book_Exchange.Models.ShipmentStatus.Delivered
                   || Model.Status == Book_Exchange.Models.ShipmentStatus.Cancelled;

    // Build the list of allowed next statuses for the dropdown
    var nextStatuses = new List<Book_Exchange.Models.ShipmentStatus>();
    if (!isTerminal)
    {
        nextStatuses = Model.Status switch
        {
            Book_Exchange.Models.ShipmentStatus.Pending      => new() { Book_Exchange.Models.ShipmentStatus.Quoted },
            Book_Exchange.Models.ShipmentStatus.Quoted       => new() { Book_Exchange.Models.ShipmentStatus.LabelCreated },
            Book_Exchange.Models.ShipmentStatus.LabelCreated => new() { Book_Exchange.Models.ShipmentStatus.Shipped },
            Book_Exchange.Models.ShipmentStatus.Shipped      => new() { Book_Exchange.Models.ShipmentStatus.Delivered },
            _                                                 => new()
        };
    }
}

<div id="shipping-details-page" class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div id="shipping-details-success-alert" class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* ── Update Status & Cancel — only shown to the sender on non-terminal shipments ── *@
    @if (isSender && !isTerminal)
    {
        <div id="shipping-update-status-card" class="card mb-4">
            <div class="card-header">Update Status</div>
            <div class="card-body">
                <form id="shipping-update-status-form" asp-action="UpdateStatus" method="post"
                      class="d-flex align-items-end gap-3 flex-wrap">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div>
                        <label class="form-label" for="shipping-new-status-select">New Status</label>
                        <select id="shipping-new-status-select" name="newStatus" class="form-select">
                            @foreach (var s in nextStatuses)
                            {
                                <option value="@s">@GetStatusDisplayName(s)</option>
                            }
                        </select>
                    </div>
                    <button id="shipping-update-status-btn" type="submit" class="btn btn-success">Update</button>
                </form>
            </div>
        </div>

        <form asp-action="Cancel" method="post" class="mb-4"
              onsubmit="return confirm('Cancel this shipment?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button id="shipping-cancel-btn" type="submit" class="btn btn-danger">Cancel Shipment</button>
        </form>
    }

    @* ── Heading + status badge ── *@
    <div id="shipping-details-card" class="d-flex justify-content-between align-items-center mb-3">
        <h2>Shipment @shipmentRef</h2>
        <span id="shipping-status-badge"
              class="badge fs-6 @GetStatusBadgeClass(Model.Status)">@GetStatusDisplayName(Model.Status)</span>
    </div>

    @* ── Address cards ── *@
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-primary h-100">
                <div class="card-header bg-primary text-white">
                    Your Details — <strong>@myRole</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Name</dt>
                        <dd id="shipping-sender-address" class="col-sm-7">@myAddress.FullName</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-secondary h-100">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <span>@theirRole Details</span>
                    <span class="badge bg-light text-dark">View only</span>
                </div>
                <div class="card-body text-muted">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Name</dt>
                        <dd id="shipping-receiver-address" class="col-sm-7">@theirAddress.FullName</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @* ── Shipment info ── *@
    <div class="card">
        <div class="card-header">Shipment Info</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Carrier</dt>
                <dd id="shipping-carrier-name" class="col-sm-8">@(Model.Carrier?.Name ?? "—")</dd>

                <dt class="col-sm-4">Reference</dt>
                <dd id="shipping-transaction-id" class="col-sm-8">@shipmentRef</dd>

                <dt class="col-sm-4">Weight</dt>
                <dd id="shipping-package-weight" class="col-sm-8">@Model.PackageWeightGrams g</dd>

                <dt class="col-sm-4">Distance</dt>
                <dd id="shipping-distance-km" class="col-sm-8">
                    @(Model.DistanceKm.HasValue ? $"{Model.DistanceKm:F1} km" : "—")
                </dd>

                <dt class="col-sm-4">Shipping Cost</dt>
                <dd id="shipping-cost-value" class="col-sm-8">
                    @(Model.ShippingCost.HasValue ? Model.ShippingCost.Value.ToString("C") : "—")
                </dd>

                @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                {
                    <dt class="col-sm-4">Tracking #</dt>
                    <dd class="col-sm-8">@Model.TrackingNumber</dd>
                }

                <dt class="col-sm-4">Created</dt>
                <dd id="shipping-created-at" class="col-sm-8">
                    @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                </dd>
            </dl>
        </div>
    </div>

    @if (!isSender)
    {
        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle me-1"></i>
            You are the <strong>receiver</strong> on this shipment. Only the sender can update or cancel it.
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-link">← Back to My Shipments</a>
    </div>
</div>

@functions {
    static string GetStatusDisplayName(Book_Exchange.Models.ShipmentStatus status) => status switch
    {
        Book_Exchange.Models.ShipmentStatus.LabelCreated => "Label Created",
        _ => status.ToString()
    };

    static string GetStatusBadgeClass(Book_Exchange.Models.ShipmentStatus status) => status switch
    {
        Book_Exchange.Models.ShipmentStatus.Quoted       => "bg-info text-dark",
        Book_Exchange.Models.ShipmentStatus.LabelCreated => "bg-info text-dark",
        Book_Exchange.Models.ShipmentStatus.Shipped      => "bg-warning text-dark",
        Book_Exchange.Models.ShipmentStatus.Delivered    => "bg-success",
        Book_Exchange.Models.ShipmentStatus.Cancelled    => "bg-danger",
        _                                                => "bg-secondary"
    };
}
