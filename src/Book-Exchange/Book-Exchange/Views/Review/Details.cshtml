@model Book_Exchange.Models.Review

@{
    ViewData["Title"] = "Review Details";

    var listingOwner   = Model.Transaction?.ExchangeRequest?.TargetListing?.User;
    var requesterId    = Model.Transaction?.ExchangeRequest?.RequesterId ?? Guid.Empty;
    var listingOwnerId = listingOwner?.Id ?? Guid.Empty;

    string revieweeName;
    Guid   revieweeId;

    if (Model.ReviewerId == listingOwnerId)
    {
        @* // Reviewer is the listing owner → reviewee is the requester.
        // The requester navigation property is not included by the service,
        // so we show the ID as a fallback for the name until Requester is included. *@
        revieweeName = Model.Transaction?.ExchangeRequest?.Requester?.UserName
                       ?? $"User {requesterId}";
        revieweeId   = requesterId;
    }
    else
    {
        @* // Reviewer is the requester → reviewee is the listing owner. *@
        revieweeName = listingOwner?.UserName ?? "Unknown";
        revieweeId   = listingOwnerId;
    }
}

<div class="container mt-4" style="max-width: 600px;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0">Review Details</h2>
        <a id="review-back-link"
           asp-action="GetUser"
           asp-controller="Review"
           asp-route-userId="@revieweeId"
           class="btn btn-outline-secondary btn-sm">
            &larr; Back to Reviews
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">

            <div id="review-detail-stars" class="mb-3" style="font-size:2rem;color:#f5a623;">
                @for (int i = 1; i <= 5; i++)
                {
                    <span>@(i <= Model.Rating ? "★" : "☆")</span>
                }
                <span class="fs-5 text-muted ms-2">@Model.Rating / 5</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Comment))
            {
                <blockquote id="review-detail-comment" class="blockquote mb-3">
                    <p class="mb-0">@Model.Comment</p>
                </blockquote>
            }
            else
            {
                <p id="review-detail-comment" class="text-muted fst-italic mb-3">No comment left.</p>
            }

            <hr />

            <dl class="row mb-0 small">
                <dt class="col-sm-4 text-muted">Reviewer</dt>
                <dd id="review-detail-reviewer" class="col-sm-8">
                    @(Model.Reviewer?.UserName ?? "Unknown")
                </dd>

                <dt class="col-sm-4 text-muted">Reviewed</dt>
                <dd id="review-detail-reviewee" class="col-sm-8">@revieweeName</dd>

                <dt class="col-sm-4 text-muted">Date</dt>
                <dd id="review-detail-date" class="col-sm-8">
                    @Model.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")
                </dd>

                <dt class="col-sm-4 text-muted">Transaction</dt>
                <dd class="col-sm-8">
                    <a id="review-detail-transaction-link"
                       asp-action="Details"
                       asp-controller="Transaction"
                       asp-route-id="@Model.TransactionId">
                        @Model.TransactionId
                    </a>
                </dd>
            </dl>

        </div>
    </div>
</div>
