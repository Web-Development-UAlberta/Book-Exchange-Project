@model IEnumerable<Book_Exchange.Models.DTOs.ExchangeRequest.ExchangeRequestViewDto>
@using Book_Exchange.Models
@using System.Security.Claims

@{
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        No exchange requests found.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var request in Model)
        {
            var isOwner = currentUserId == request.OwnerId.ToString();

            <div class="col-md-6 col-lg-4">
                <div class="exchange-request-card card h-100 shadow-sm">

                    <div class="text-center p-3 bg-light border-bottom">
                        @if (!string.IsNullOrWhiteSpace(request.TargetBook?.ThumbnailUrl))
                        {
                            <img src="@request.TargetBook.ThumbnailUrl"
                                 alt="@request.TargetBook.Title"
                                 class="img-fluid"
                                 style="height:180px; object-fit:contain;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-secondary-subtle"
                                 style="height:180px;">
                                <span class="text-muted">No Cover</span>
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">

                        <h5 class="exchange-book-title mb-1">
                            @(request.TargetBook?.Title ?? "Unknown Book")
                        </h5>

                        <div class="text-muted small mb-3">
                            @(request.TargetBook?.Authors != null && request.TargetBook.Authors.Any()
                                ? string.Join(", ", request.TargetBook.Authors)
                                : "Unknown Author")
                        </div>

                        <div class="small mb-1">
                            <strong>ISBN:</strong> @request.TargetIsbn
                        </div>

                        <div class="small mb-1">
                            <strong>Status:</strong>
                            <span class="exchange-status badge bg-secondary">
                                @request.Status
                            </span>
                        </div>

                        <div class="small mb-1">
                            <strong>Requester:</strong> @request.RequesterName
                        </div>

                        <div class="small mb-1">
                            <strong>Owner:</strong> @request.OwnerName
                        </div>

                        @if (request.Price.HasValue)
                        {
                            <div class="small mb-1">
                                <strong>Cash offer:</strong> $@request.Price
                            </div>
                        }

                        @if (request.OfferedBooks != null && request.OfferedBooks.Any())
                        {
                            <div class="small mt-2">
                                <strong>Offered:</strong>
                                @string.Join(", ", request.OfferedBooks.Select(b => b.Title ?? b.Isbn13 ?? b.Isbn10 ?? "Unknown"))
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(request.Message))
                        {
                            <div class="small mt-2 text-muted">
                                <strong>Message:</strong> @request.Message
                            </div>
                        }

                        <div class="mt-auto pt-3 d-grid gap-2">

                            <a class="exchange-details-btn btn btn-outline-primary btn-sm"
                               asp-controller="ExchangeRequest"
                               asp-action="Details"
                               asp-route-id="@request.Id">
                                Details
                            </a>

                            @if (isOwner && request.Status == ExchangeStatus.Requested)
                            {
                                <div class="d-flex gap-2">
                                    <form asp-controller="ExchangeRequest"
                                          asp-action="Accept"
                                          asp-route-id="@request.Id"
                                          method="post"
                                          class="w-100">
                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="exchange-accept-btn btn btn-success btn-sm w-100">
                                            Accept
                                        </button>
                                    </form>

                                    <form asp-controller="ExchangeRequest"
                                          asp-action="Reject"
                                          asp-route-id="@request.Id"
                                          method="post"
                                          class="w-100">
                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="exchange-reject-btn btn btn-danger btn-sm w-100">
                                            Reject
                                        </button>
                                    </form>
                                </div>
                            }

                        </div>

                    </div>

                </div>
            </div>
        }
    </div>
}